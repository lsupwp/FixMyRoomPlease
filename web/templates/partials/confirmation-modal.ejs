<!-- Confirmation Modal -->
<div id="confirmationModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 p-4">
    <div class="rounded-2xl border border-gray-200 bg-white shadow-lg sm:max-w-md w-full">
        <div class="border-b border-gray-200 p-6">
            <h3 id="confirmModalTitle" class="text-lg font-semibold text-gray-900"></h3>
            <p id="confirmModalMessage" class="mt-2 text-sm text-gray-600"></p>
        </div>
        <div class="flex gap-3 p-6">
            <button 
                type="button"
                onclick="closeConfirmationModal()"
                id="confirmModalCancelBtn"
                class="flex-1 rounded-full border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
                ยกเลิก
            </button>
            <button 
                type="button"
                onclick="handleConfirmation()"
                id="confirmModalConfirmBtn"
                class="flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition">
                ยืนยัน
            </button>
        </div>
    </div>
</div>

<script>
    let confirmCallback = null;

    function openConfirmationModal(options) {
        const {
            title = 'ยืนยันการดำเนินการ',
            message = 'คุณแน่ใจหรือว่าต้องการดำเนินการต่อ?',
            confirmText = 'ยืนยัน',
            cancelText = 'ยกเลิก',
            confirmColor = 'bg-blue-600 hover:bg-blue-500',
            onConfirm = null
        } = options;

        const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
        const isMobile = window.innerWidth < 640;
        const blurAmount = isMobile ? '100px' : '4px';
        
        // Update modal content
        document.getElementById('confirmModalTitle').textContent = title;
        document.getElementById('confirmModalMessage').textContent = message;
        document.getElementById('confirmModalCancelBtn').textContent = cancelText;
        document.getElementById('confirmModalConfirmBtn').textContent = confirmText;
        
        // Update button colors
        const confirmBtn = document.getElementById('confirmModalConfirmBtn');
        confirmBtn.className = `flex-1 rounded-full px-4 py-2 text-sm font-semibold text-white transition ${confirmColor}`;
        
        // Store callback
        confirmCallback = onConfirm;
        
        // Show modal
        document.getElementById('confirmationModal').classList.remove('hidden');
        document.getElementById('confirmationModal').style.backdropFilter = `blur(${blurAmount})`;
        document.body.style.overflow = 'hidden';
        if (scrollbarWidth > 0) {
            document.body.style.paddingRight = scrollbarWidth + 'px';
        }
    }

    function closeConfirmationModal() {
        document.getElementById('confirmationModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
        document.body.style.paddingRight = '0px';
        confirmCallback = null;
    }

    function handleConfirmation() {
        if (confirmCallback && typeof confirmCallback === 'function') {
            confirmCallback();
        }
        closeConfirmationModal();
    }

    // Close modal when clicking outside
    document.getElementById('confirmationModal')?.addEventListener('click', (e) => {
        if (e.target.id === 'confirmationModal') {
            closeConfirmationModal();
        }
    });
</script>
