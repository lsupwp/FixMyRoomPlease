<%- include("./template", {
    title: `แก้ไขรายงาน #${String(report.id).padStart(3, '0')}`,
    content: `
        <div class="grid gap-6 sm:gap-8">
            <div class="flex items-center gap-3">
                <a href="/report/${report.id}" class="flex h-9 w-9 items-center justify-center rounded-full transition hover:bg-gray-100">
                    <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <div>
                    <h2 class="text-2xl font-semibold tracking-tight">แก้ไขรายงาน</h2>
                    <p class="text-sm text-gray-500">รายงาน #${String(report.id).padStart(3, '0')} • ห้อง ${report.roomNumber}</p>
                </div>
            </div>
` + (error ? `
            <div id="errorAlert" class="rounded-2xl border border-red-200 bg-red-50 p-4 shadow-sm">
                <div class="flex items-start gap-3">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-red-600">
                        <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-sm font-semibold text-red-900">เกิดข้อผิดพลาด</h3>
                        <p class="mt-1 text-sm text-red-700">${error}</p>
                    </div>
                    <button 
                        type="button" 
                        onclick="document.getElementById('errorAlert').remove()"
                        class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-red-600 transition hover:bg-red-100"
                    >
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
` : '') + `
            <form id="editForm" method="POST" action="/report/${report.id}/update" enctype="multipart/form-data" class="grid gap-6">
                <input type="hidden" name="deletedImages" id="deletedImages" value="">
                
                <!-- Description -->
                <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                    <label class="block text-sm font-semibold text-gray-900">รายละเอียดปัญหา</label>
                    <textarea 
                        name="description"
                        rows="5"
                        class="mt-3 w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 shadow-sm outline-none transition focus:border-blue-400 focus:bg-white focus:ring-2 focus:ring-blue-200 resize-none"
                    >${report.description}</textarea>
                </div>

                <!-- Images -->
                <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                    <label class="block text-sm font-semibold text-gray-900">รูปภาพแนบ</label>
                    
                    <!-- Upload Area -->
                    <div class="mt-4 mb-6">
                        <label class="block cursor-pointer">
                            <div 
                                id="uploadArea"
                                class="rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 p-8 text-center transition hover:border-blue-400 hover:bg-blue-50"
                            >
                                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                                <p class="mt-2 text-sm font-semibold text-gray-900">ลากรูปภาพมาวางที่นี่</p>
                                <p class="text-xs text-gray-500">หรือคลิกเลือกไฟล์</p>
                            </div>
                            <input 
                                type="file" 
                                name="images"
                                id="fileInput"
                                multiple 
                                accept="image/*"
                                class="hidden"
                            >
                        </label>
                    </div>

                    <!-- All Images Grid -->
                    ${report.images && report.images.length > 0 ? `
                        <div class="mt-4">
                            <p class="mb-3 text-xs text-gray-600">รูปภาพ</p>
                            <div id="allImagesGrid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
                                ${report.images.map((img, idx) => `
                                    <div class="relative overflow-hidden rounded-xl bg-gray-200" data-image-id="${img.image_id}">
                                        <img src="${img.image_url}" alt="${img.placeholder || 'รูปภาพ'}" class="h-32 w-full object-cover">
                                        <button 
                                            type="button" 
                                            onclick="removeImage(this, ${img.image_id})"
                                            class="absolute top-2 right-2 rounded-full bg-red-500 p-1.5 shadow-lg transition hover:bg-red-600"
                                        >
                                            <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                        </button>
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                    ` : `
                        <div class="mt-4">
                            <p class="mb-3 text-xs text-gray-600">รูปภาพ</p>
                            <div id="allImagesGrid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"></div>
                        </div>
                    `}
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col gap-3 sm:flex-row">
                    <a href="/report/${report.id}" class="rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 text-center transition hover:bg-gray-50">
                        ยกเลิก
                    </a>
                    <button type="button" onclick="confirmSaveChanges()" class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-500">
                        บันทึกการเปลี่ยนแปลง
                    </button>
                </div>
            </form>
        </div>

        <script src="/scripts/tenant/report-edit.js"></script>
    `
}) %>

<%- include('../partials/confirmation-modal') %>
