<!-- Cancel Confirmation Modal -->
<div id="cancelModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 p-4">
    <div class="rounded-2xl border border-gray-200 bg-white shadow-lg sm:max-w-md">
        <div class="border-b border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900">ยกเลิกรายงาน</h3>
            <p class="mt-2 text-sm text-gray-600">คุณแน่ใจหรือว่ากำลังจะยกเลิกรายงานนี้? การดำเนินการนี้ไม่สามารถยกเลิกได้</p>
        </div>
        <div class="flex gap-3 p-6">
            <button 
                type="button"
                onclick="closeCancelModal()"
                class="flex-1 rounded-full border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
                ไม่
            </button>
            <form id="cancelForm" method="POST" action="/report/<%= typeof reportId !== 'undefined' ? reportId : '' %>/cancel" class="flex-1">
                <button 
                    type="submit"
                    class="w-full rounded-full bg-red-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-500">
                    ใช่ ยกเลิกรายงาน
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function openCancelModal(reportIdParam) {
        const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
        const isMobile = window.innerWidth < 640;
        const blurAmount = isMobile ? '100px' : '4px';
        
        // If reportIdParam is provided, update the form action
        if (reportIdParam) {
            document.getElementById('cancelForm').action = `/report/${reportIdParam}/cancel`;
        }
        
        document.getElementById('cancelModal').classList.remove('hidden');
        document.getElementById('cancelModal').style.backdropFilter = `blur(${blurAmount})`;
        document.body.style.overflow = 'hidden';
        if (scrollbarWidth > 0) {
            document.body.style.paddingRight = scrollbarWidth + 'px';
        }
    }

    function closeCancelModal() {
        document.getElementById('cancelModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
        document.body.style.paddingRight = '0px';
    }

    // Close modal when clicking outside
    document.getElementById('cancelModal').addEventListener('click', (e) => {
        if (e.target.id === 'cancelModal') {
            closeCancelModal();
        }
    });
</script>
