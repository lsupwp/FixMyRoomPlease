<%- include("./template", {
    title: "รายงานของฉัน",
    content: `
        <div class="grid gap-6 sm:gap-8">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-2xl font-semibold tracking-tight">รายงานของฉัน</h2>
                    <p class="text-sm text-gray-500">ติดตามสถานะปัญหาที่คุณแจ้งไปแล้ว</p>
                </div>
                <a href="/" class="w-full rounded-full border border-blue-600 px-6 py-2 text-center text-sm font-semibold text-blue-600 shadow-sm transition hover:bg-blue-50 sm:w-auto">
                    + แจ้งปัญหาใหม่
                </a>
            </div>

            <div class="grid gap-4">
                ${(reports && reports.length > 0) ? reports.map((report) => `
                <!-- Report Card -->
                <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm ${report.status === 'resolved' || report.status === 'cancelled' ? 'opacity-75' : ''} sm:p-6">
                    <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div class="flex-1">
                            <h3 class="text-lg font-semibold text-gray-900">${report.title}</h3>
                            <p class="mt-1 text-xs text-gray-500">รายงาน #${String(report.id).padStart(3, '0')} • ห้อง ${report.roomNumber}</p>
                        </div>
                        <span class="inline-block w-fit rounded-full ${report.badge.bg} px-3 py-1 text-xs font-semibold ${report.badge.text}">
                            ${report.badge.label}
                        </span>
                    </div>
                    <div class="mb-4">
                        <p class="text-sm text-gray-700">${report.description}</p>
                        ${report.images && report.images.length > 0 ? `
                            <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
                                ${report.images.map((img) => `
                                    <div class="overflow-hidden rounded-xl bg-gray-200">
                                        ${img.image_url ? `
                                            <img src="${img.image_url}" alt="${img.placeholder || 'รูปภาพ'}" class="h-24 w-full object-cover">
                                        ` : `
                                            <div class="h-24 bg-gradient-to-br ${img.gradient} flex items-center justify-center text-xs text-white font-semibold">
                                                ${img.placeholder}
                                            </div>
                                        `}
                                    </div>
                                `).join('')}
                            </div>
                        ` : ''}
                    </div>
                    <div class="flex flex-col gap-2 border-t border-gray-200 pt-4 sm:flex-row">
                        <span class="text-xs text-gray-500">
                            แจ้ง: ${report.createdDate}${report.createdTime ? ` เวลา ${report.createdTime}` : ''}${report.updatedDate ? ` • แก้ไข: ${report.updatedDate}` : ''}
                        </span>
                        <div class="flex flex-col gap-2 sm:ml-auto sm:flex-row">
                            <a href="/report/${report.id}" class="rounded-full border border-gray-300 px-4 py-2 text-xs font-semibold text-gray-700 text-center transition hover:bg-gray-50">
                                ดูรายละเอียด
                            </a>
                            ${report.status !== 'resolved' && report.status !== 'cancelled' ? `
                                <button type="button" onclick="openCancelModal(${report.id})" class="rounded-full bg-red-50 px-4 py-2 text-xs font-semibold text-red-600 transition hover:bg-red-100">
                                    ยกเลิกรายงาน
                                </button>
                            ` : ''}
                        </div>
                    </div>
                </div>
                `).join('') : `
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-gray-300 bg-gray-50 px-6 py-16">
                    <svg class="mb-4 h-20 w-20 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <h3 class="mb-2 text-lg font-semibold text-gray-900">ยังไม่มีการรายงาน</h3>
                    <p class="mb-6 text-center text-sm text-gray-500">คุณยังไม่ได้แจ้งปัญหาใดๆ<br>เริ่มต้นด้วยการแจ้งปัญหาใหม่</p>
                    <a href="/" class="rounded-full bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700">
                        + แจ้งปัญหาใหม่
                    </a>
                </div>
                `}
            </div>
        </div>
    `
}) %>

<%- include('./partials/cancel-modal', { reportId: 0 }) %>
