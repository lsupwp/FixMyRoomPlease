<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <title>รายงาน #<%= String(report.id).padStart(3, '0') %></title>
</head>
<body class="min-h-screen bg-gradient-to-b from-gray-200 via-gray-100 to-gray-200 text-gray-900" style="font-family: 'Space Grotesk', sans-serif;">
    <%- include('./partials/header') %>

    <div class="w-full px-4 sm:px-6 lg:px-10">
        <main class="py-8 sm:py-10">
            <section class="w-full rounded-2xl border border-gray-300/80 bg-gray-50/80 p-5 shadow-sm sm:p-8">
                <div class="grid gap-6 sm:gap-8">
                    <div class="flex items-center gap-3">
                        <a href="/view-report" class="flex h-9 w-9 items-center justify-center rounded-full transition hover:bg-gray-100">
                            <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                            </svg>
                        </a>
                        <div class="flex-1">
                            <h2 class="text-2xl font-semibold tracking-tight">รายงาน #<%= String(report.index).padStart(3, '0') %> • ห้อง <%= report.roomNumber %></h2>
                        </div>
                        <span class="inline-block rounded-full <%= report.badge.bg %> px-4 py-2 text-xs font-semibold <%= report.badge.text %>">
                            <%= report.badge.label %>
                        </span>
                    </div>

                    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                        <div class="mb-6">
                            <h3 class="mb-2 text-sm font-semibold text-gray-900">รายละเอียดปัญหา</h3>
                            <p class="text-sm leading-relaxed text-gray-700"><%= report.description %></p>
                        </div>

                        <% if (report.images && report.images.length > 0) { %>
                            <div class="mb-6">
                                <h3 class="mb-3 text-sm font-semibold text-gray-900">รูปภาพแนบ (<%= report.images.length %>)</h3>
                                <div class="grid grid-cols-1 gap-3 min-[420px]:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
                                    <% report.images.forEach(function (img) { %>
                                        <div class="overflow-hidden rounded-xl bg-gray-200 pointer-events-none select-none">
                                            <% if (img.image_url) { %>
                                                <img src="<%= img.image_url %>" alt="<%= img.placeholder || 'รูปภาพ' %>" class="h-40 w-full object-cover sm:h-48" draggable="false">
                                            <% } else { %>
                                                <div class="h-40 bg-gradient-to-br <%= img.gradient %> flex items-center justify-center text-sm text-white font-semibold sm:h-48">
                                                    <%= img.placeholder %>
                                                </div>
                                            <% } %>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        <% } %>

                        <div class="border-t border-gray-200 pt-5">
                            <div class="grid gap-4 sm:grid-cols-2">
                                <div>
                                    <p class="text-xs font-semibold text-gray-500">วันที่แจ้ง</p>
                                    <p class="mt-1 text-sm text-gray-900">
                                        <%= report.createdDate %><% if (report.createdTime) { %> เวลา <%= report.createdTime %><% } %>
                                    </p>
                                </div>
                                <% if (report.updatedDate) { %>
                                    <div>
                                        <p class="text-xs font-semibold text-gray-500">วันที่แก้ไข</p>
                                        <p class="mt-1 text-sm text-gray-900"><%= report.updatedDate %></p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <% if (report.status !== 'resolved' && report.status !== 'cancelled') { %>
                        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                            <h3 class="mb-4 text-sm font-semibold text-gray-900">การดำเนินการ</h3>
                            <div class="flex flex-col gap-3 sm:flex-row">
                                <a href="/report/<%= report.id %>/edit" class="w-full rounded-full border border-gray-300 px-6 py-3 text-center text-sm font-semibold text-gray-700 transition hover:bg-gray-50 sm:w-auto">
                                    ✏️ แก้ไขรายงาน
                                </a>
                                <button
                                    type="button"
                                    onclick="openCancelModal()"
                                    class="w-full rounded-full bg-red-50 px-6 py-3 text-sm font-semibold text-red-600 transition hover:bg-red-100 sm:w-auto">
                                    ยกเลิกรายงาน
                                </button>
                                <a href="/chat" class="ml-auto w-full rounded-full bg-blue-600 px-6 py-3 text-center text-sm font-semibold text-white transition hover:bg-blue-500 sm:w-auto">
                                    💬 ติดต่อ Admin
                                </a>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                            <% if (report.status === 'resolved') { %>
                                <div class="flex items-start gap-3">
                                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-green-600 text-white">
                                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="text-sm font-semibold text-green-900">ปัญหาได้รับการแก้ไขแล้ว</h3>
                                        <p class="mt-1 text-sm text-green-700">รายงานนี้ได้รับการดำเนินการเสร็จสิ้นแล้ว หากยังมีปัญหา กรุณาแจ้งใหม่อีกครั้ง</p>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="flex items-start gap-3">
                                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gray-400 text-white">
                                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="text-sm font-semibold text-gray-900">รายงานได้ถูกยกเลิกแล้ว</h3>
                                        <p class="mt-1 text-sm text-gray-600">รายงานนี้ได้ถูกยกเลิก หากต้องการแจ้งปัญหาใหม่ กรุณา <a href="/" class="font-semibold text-blue-600 hover:underline">แจ้งปัญหาใหม่</a></p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

    <%- include('./partials/cancel-modal', { reportId: report.id }) %>
</body>
</html>
