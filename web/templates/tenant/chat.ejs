<%- include("./template", {
    title: "แชท",
    content: `
        <div class="flex flex-col gap-6 sm:gap-8 h-full">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-2xl font-semibold tracking-tight">แชท</h2>
                    <p class="text-sm text-gray-500">คุยกับ Admin Support</p>
                </div>
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100 text-sm font-semibold text-green-700">
                    🟢
                </div>
            </div>

            <div class="flex-1 overflow-y-auto rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                ${(messages || []).map((msg) => {
                    const isOwn = msg.sender === userRole;
                    return `
                    <div class="mb-4">
                        <div class="flex gap-3 max-w-xs ${isOwn ? 'flex-row-reverse ml-auto' : 'flex-row mr-auto'}">
                            ${!isOwn ? `
                                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-semibold text-white">
                                    ${msg.senderAvatar || '?'}
                                </div>
                            ` : ''}
                            <div class="flex flex-col gap-1 ${isOwn ? 'items-end' : 'items-start'}">
                                <span class="text-xs font-semibold text-gray-600">${msg.senderName}</span>
                                <div class="rounded-2xl px-4 py-2 ${isOwn ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-900'}">
                                    <p class="text-sm">${msg.message}</p>
                                </div>
                                <span class="text-xs text-gray-500">${msg.timestamp}</span>
                            </div>
                        </div>
                    </div>
                    `;
                }).join('')}
            </div>

            <div class="flex gap-3">
                <input 
                    type="text" 
                    placeholder="พิมพ์ข้อความ..."
                    class="flex-1 w-full rounded-full border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 shadow-sm outline-none transition focus:border-blue-400 focus:bg-white focus:ring-2 focus:ring-blue-200"
                >
                <button class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-300">
                    ส่ง
                </button>
            </div>
        </div>
    `
}) %>
