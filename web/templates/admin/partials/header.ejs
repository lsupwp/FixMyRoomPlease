<header class="w-full px-4 sm:px-6 lg:px-10 pt-6">
        <div class="w-full rounded-2xl border border-gray-300/80 bg-gray-50/80 px-4 py-4 shadow-sm sm:px-6 sm:py-5">
            <div class="flex items-center justify-between gap-4">
                <div class="flex min-w-0 items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-2xl bg-gray-100 sm:h-10 sm:w-10">
                        <img src="/images/logo.png" alt="FixMyRoom logo" class="h-7 w-7 rounded-xl object-contain sm:h-8 sm:w-8"/>
                    </div>
                    <div>
                        <a href="/admin/problems" class="text-base font-semibold tracking-tight sm:text-xl">FixMyRoomPlease</a>
                        <p class="text-xs text-gray-600 sm:text-sm">Minimal tenant workspace</p>
                    </div>
                </div>

                <details class="relative shrink-0">
                    <summary class="cursor-pointer list-none rounded-full bg-blue-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-300">
                        Menu
                    </summary>
                    <div class="absolute right-0 mt-3 w-48 rounded-2xl border border-gray-300 bg-gray-50 p-2 shadow-lg sm:w-56">
                        <a class="block rounded-xl px-3 py-2 text-sm text-gray-700 hover:bg-gray-200/70" href="/admin/problems">จัดการปัญหา</a>
                        <a class="block rounded-xl px-3 py-2 text-sm text-gray-700 hover:bg-gray-200/70" href="/admin/chat">แชท</a>
                        <a class="block rounded-xl px-3 py-2 text-sm text-gray-700 hover:bg-gray-200/70" href="/logout">ออกจากระบบ</a>
                        <span class="block rounded-xl px-3 py-2 text-xs font-semibold text-gray-600">
                            <%= username || 'Admin' %>
                        </span>
                    </div>
                </details>
            </div>
        </div>
</header>