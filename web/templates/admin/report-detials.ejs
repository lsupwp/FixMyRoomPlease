<!DOCTYPE html>
<html lang="th">
<head>
    <%- include('../head') %>
    <title>รายงาน #<%= String(problem.id).padStart(3, '0') %></title>
</head>
<body class="min-h-screen bg-gradient-to-b from-gray-200 via-gray-100 to-gray-200 text-gray-900" style="font-family: 'Space Grotesk', sans-serif;" data-problem-id="<%= problem.id %>">
    <%- include('./partials/header') %>

    <div class="w-full px-4 sm:px-6 lg:px-10">
        <main class="py-8 sm:py-10">
            <section class="w-full rounded-2xl border border-gray-300/80 bg-gray-50/80 p-5 shadow-sm sm:p-8">
                <div class="grid gap-6 sm:gap-8">
                    <div class="flex items-center gap-3">
                        <a href="/admin/problems" class="flex h-9 w-9 items-center justify-center rounded-full transition hover:bg-gray-100">
                            <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                            </svg>
                        </a>
                        <div class="flex-1">
                            <h2 class="text-2xl font-semibold tracking-tight">
                                รายงาน #<%= String(problem.id).padStart(3, '0') %> • 
                                ห้อง <%= problem.roomNumber %> • 
                                <span class="font-medium">@<%= problem.username %></span>
                            </h2>
                        </div>
                        <span class="inline-block rounded-full <%= problem.badge.bg %> px-4 py-2 text-xs font-semibold <%= problem.badge.text %>">
                            <%= problem.badge.label %>
                        </span>
                    </div>

                    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                        <div class="mb-6">
                            <h3 class="mb-2 text-sm font-semibold text-gray-900">รายละเอียดปัญหา</h3>
                            <p class="text-sm leading-relaxed text-gray-700"><%= problem.description %></p>
                        </div>

                        <% if (problem.images && problem.images.length > 0) { %>
                            <div class="mb-6">
                                <h3 class="mb-3 text-sm font-semibold text-gray-900">รูปภาพแนบ (<%= problem.images.length %>)</h3>
                                <div class="grid grid-cols-1 gap-3 min-[420px]:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
                                    <% problem.images.forEach(function (img) { %>
                                        <div class="overflow-hidden rounded-xl bg-gray-200 cursor-pointer transition hover:opacity-90">
                                            <% if (img.image_url) { %>
                                                <img src="<%= img.image_url %>" alt="<%= img.placeholder || 'รูปภาพ' %>" class="h-40 w-full object-cover sm:h-48">
                                            <% } else { %>
                                                <div class="h-40 bg-gradient-to-br <%= img.gradient %> flex items-center justify-center text-sm text-white font-semibold sm:h-48">
                                                    <%= img.placeholder %>
                                                </div>
                                            <% } %>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        <% } %>

                        <div class="border-t border-gray-200 pt-5">
                            <div class="grid gap-4 sm:grid-cols-2">
                                <div>
                                    <p class="text-xs font-semibold text-gray-500">ผู้แจ้ง</p>
                                    <p class="mt-1 text-sm text-gray-900">
                                        <%= problem.username %> (ห้อง <%= problem.roomNumber %>)
                                    </p>
                                </div>
                                <div>
                                    <p class="text-xs font-semibold text-gray-500">วันที่แจ้ง</p>
                                    <p class="mt-1 text-sm text-gray-900">
                                        <%= problem.createdDate %><% if (problem.createdTime) { %> เวลา <%= problem.createdTime %><% } %>
                                    </p>
                                </div>
                                <% if (problem.updatedDate) { %>
                                    <div>
                                        <p class="text-xs font-semibold text-gray-500">อัพเดทล่าสุด</p>
                                        <p class="mt-1 text-sm text-gray-900"><%= problem.updatedDate %></p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <% if (problem.status !== 'resolved' && problem.status !== 'cancelled') { %>
                        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                            <h3 class="mb-4 text-sm font-semibold text-gray-900">การดำเนินการ</h3>
                            <div class="flex flex-col gap-3 sm:flex-row">
                                <button
                                    type="button"
                                    onclick="markAsResolved()"
                                    class="w-full rounded-full bg-green-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-green-500 sm:w-auto">
                                    ✓ ทำเครื่องหมายว่าแก้ไขเสร็จแล้ว
                                </button>
                                <a href="/admin/chat?tenant=<%= problem.username %>" class="w-full rounded-full border border-gray-300 px-6 py-3 text-center text-sm font-semibold text-gray-700 transition hover:bg-gray-50 sm:w-auto">
                                    💬 ติดต่อผู้แจ้ง
                                </a>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm flex flex-wrap items-center justify-between gap-4">
                            <% if (problem.status === 'resolved') { %>
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-green-600 text-white">
                                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-semibold text-green-900">ปัญหาได้รับการแก้ไขแล้ว</h3>
                                        <p class="text-sm text-green-700">รายงานนี้ได้รับการดำเนินการเสร็จสิ้นแล้ว</p>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gray-400 text-white">
                                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="text-sm font-semibold text-gray-900">รายงานได้ถูกยกเลิกแล้ว</h3>
                                        <p class="text-sm text-gray-600">ผู้แจ้งได้ยกเลิกรายงานนี้แล้ว</p>
                                    </div>
                                </div>
                            <% } %>
                            <a href="/admin/chat?tenant=<%= problem.username %>" class="inline-flex items-center gap-2 rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 shrink-0">
                                💬 แชทกับคนเช่า
                            </a>
                        </div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

    <script src="/scripts/admin/report-detials.js"></script>

    <%- include('../partials/confirmation-modal') %>
</body>
</html>
